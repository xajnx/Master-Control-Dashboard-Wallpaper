# Copy to .env for local overrides
DASHBOARD_API_HOST=127.0.0.1
DASHBOARD_API_PORT=5000
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:5500,http://127.0.0.1:5500
NASA_API_KEY=DEMO_KEY

# Optional: real-time Schumann JSON endpoint expected to return a numeric value
# SCHUMANN_API_URL=https://example.com/schumann.json
# Optional: dot-path override for numeric Schumann value field (e.g. data.current.value)
# SCHUMANN_VALUE_PATH=
